# =============================
# OXM 製造業平台 環境變數範本
# 複製此檔案為 .env，填入實際值後啟動
# =============================

# ── 資料庫 ──────────────────────
# 格式：mysql://帳號:密碼@主機:埠號/資料庫名稱
DATABASE_URL=mysql://root:yourpassword@localhost:3306/oxm

# ── Node 環境 ────────────────────
NODE_ENV=production

# ── Session / JWT ───────────────
# 上線前必須換成強密碼（至少 64 字元隨機字串）
# 生成指令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=請替換成64字元以上的隨機字串

# ── Google OAuth ────────────────
# 到 Google Cloud Console > APIs & Services > Credentials 取得
GOOGLE_CLIENT_ID=你的Google_Client_ID
GOOGLE_CLIENT_SECRET=你的Google_Client_Secret

# ── 安全 / CORS ──────────────────
# 填入正式網域，多個網域用逗號分隔
# 範例：ALLOWED_ORIGINS=https://oxm.com.tw
ALLOWED_ORIGINS=https://你的網域.com

# ── 管理員白名單 ─────────────────
# JSON 陣列格式，填入管理員的 Google 登入 Email
ADMIN_WHITELIST_EMAILS=["admin@example.com"]

# ── Email 通知（Resend）──────────
# 申請：https://resend.com
# 若未填入，Email 通知功能將無法運作（不影響其他功能）
RESEND_API_KEY=
FROM_EMAIL=noreply@你的網域.com

# ── AI 語意搜尋（Anthropic）──────
# 申請：https://console.anthropic.com
# 若未填入，搜尋將 fallback 為普通關鍵字搜尋（不影響上線）
ANTHROPIC_API_KEY=

# ── 圖片儲存（AWS S3）────────────
# 若未填入，圖片將以 base64 暫存在 DB（不建議正式環境使用）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=你的bucket名稱

# ── Server Port（選填）──────────
# 預設 3000
PORT=3000
